{
  "name": "express-vite-template",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "start": "npm run build && node -r ts-node/register -r tsconfig-paths/register -r dotenv/config dist/index.js",
    "start:dev": "nodemon --exec ts-node -r tsconfig-paths/register -r dotenv/config src/index.ts ",
    "build": "tsc",
    "lint": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "keywords": [
    "express",
    "vite",
    "nodejs",
    "typescript"
  ],
  "author": "Aneeq Khurram",
  "displayName": "Express Vite Template",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "MIT",
  "description": "",
  "dependencies": {
    "cors": "^2.8.5",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "morgan": "^1.10.0"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/**/*.spec.ts"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.31.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "dotenv": "^17.2.0",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0"
  }
}
